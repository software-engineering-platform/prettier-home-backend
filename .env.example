# Prettier Home Backend Environment Variables Configuration
# ==================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real credentials to version control

# ==================================================
# SERVER CONFIGURATION
# ==================================================
# Application server port (default: 1010 for local, 8080 for K8s)
SERVER_PORT=8080

# ==================================================
# DATABASE CONFIGURATION
# ==================================================
# PostgreSQL database connection URL
# Format: jdbc:postgresql://<host>:<port>/<database_name>
# Example for local: jdbc:postgresql://localhost:5432/prettierhomes
# Example for K8s: jdbc:postgresql://postgres.database.svc.cluster.local:5432/prettierhomes
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/prettierhomes

# Database driver class name
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Database username
SPRING_DATASOURCE_USERNAME=db_admin

# Database password (REQUIRED - no default for security)
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ==================================================
# JPA/HIBERNATE CONFIGURATION
# ==================================================
# Hibernate DDL auto mode (create, update, validate, none)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Show SQL queries in logs
SPRING_JPA_SHOW_SQL=false

# Format SQL queries
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# Database platform/dialect
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# ==================================================
# SECURITY CONFIGURATION
# ==================================================
# JWT secret key for token signing and verification (REQUIRED - no default for security)
# MUST be a strong random string (minimum 64 characters recommended)
# Generate with: openssl rand -base64 64
SECURITY_TOKEN_SECRET=your_jwt_secret_key_here_minimum_64_characters

# JWT token validity in milliseconds (default: 259200000 = 3 days)
SECURITY_TOKEN_VALIDITY=259200000

# ==================================================
# MAIL CONFIGURATION (Gmail SMTP)
# ==================================================
# Mail server host
SPRING_MAIL_HOST=smtp.gmail.com

# Mail server port
SPRING_MAIL_PORT=587

# Gmail username/email address
SPRING_MAIL_USERNAME=prettier.homes.noreply@gmail.com

# Gmail App Password (REQUIRED - no default for security)
# Generate Gmail App Password: https://myaccount.google.com/apppasswords
# Format: xxxx xxxx xxxx xxxx (spaces are OK)
SPRING_MAIL_PASSWORD=your_gmail_app_password_here

# ==================================================
# NOTES FOR DEPLOYMENT
# ==================================================
# Local Development:
#   - Use localhost for database host
#   - Copy this file to .env and source it before running the application
#   - Example: export $(cat .env | xargs) && mvn spring-boot:run
#   - Or set environment variables in your IDE run configuration
#
# Kubernetes Deployment:
#   Environment variables are sourced from multiple K8s resources:
#
#   From backend-secret (prettierhome/k8s/secrets/backend-secret.yaml):
#     - SPRING_DATASOURCE_PASSWORD
#     - SECURITY_TOKEN_SECRET (jwt-secret)
#     - SPRING_DATASOURCE_URL (database-url)
#     - SPRING_MAIL_PASSWORD (mail-password)
#
#   From postgres-secret (shared-database/k8s/secrets/postgres-secret.yaml):
#     - SPRING_DATASOURCE_USERNAME (username)
#     - SPRING_DATASOURCE_PASSWORD (password)
#     NOTE: Shared across all applications using the centralized database
#
#   From backend-config (prettierhome/k8s/configmaps/backend-configmap.yaml):
#     - SERVER_PORT
#     - SPRING_JPA_HIBERNATE_DDL_AUTO
#     - SPRING_JPA_SHOW_SQL
#     - SPRING_JPA_DATABASE_PLATFORM
#     - SPRING_DATASOURCE_DRIVER_CLASS_NAME
#     - SPRING_PROFILES_ACTIVE
#     - SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE
#     - SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE
#
#   Database URL format for K8s:
#     jdbc:postgresql://postgres.database.svc.cluster.local:5432/prettierhomes
#
# Security Best Practices:
#   - Never commit real credentials to version control
#   - Use strong, randomly generated passwords and secrets
#   - Rotate secrets periodically
#   - Use different credentials for different environments (dev, staging, prod)
#   - For Gmail, use App Passwords instead of your actual password
#   - In production, consider using secret management tools (HashiCorp Vault, AWS Secrets Manager, etc.)
#   - Database credentials are shared in K8s - coordinate changes with other applications